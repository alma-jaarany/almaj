                <td><a href="תרומת-כלב.aspx">
                    <img src="images/תרומת-כלב2.png" style="width:150px;height:75px;"></a></td>
            </tr>
            <tr style="height: 100%;">
                <td style="background-color:#caece8; height: 100%; direction: rtl; text-align:center; font-size: 20px; color: #6eaaa3; font-family: Assistant;" colspan="10">
                    <asp:ContentPlaceHolder ID="MainContent" runat="server">
                    </asp:ContentPlaceHolder>
                </td>
            </tr>
        </table>
</body>
</html>
